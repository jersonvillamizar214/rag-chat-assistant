# Copy to .env and fill in. For production (Vercel) use your Neon connection string.
DATABASE_URL="postgresql://user:password@host:5432/ragdb"

# Free API key from https://console.groq.com
GROQ_API_KEY="gsk_your_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"

# Free API key from https://aistudio.google.com/apikey (embeddings)
GEMINI_API_KEY="your_gemini_key_here"
